# ReconMaster v4.1.0-Elite Environment Variables
# Copy this file to .env and fill in your keys

# --- Core Scan Settings ---
RECON_TARGET=example.com
THREADS=50

# --- API Credentials (Required for Deep Discovery) ---
CENSYS_API_ID=
CENSYS_API_SECRET=
SECURITYTRAILS_API_KEY=
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
GITHUB_TOKEN=

# --- Alerting ---
WEBHOOK_URL=
SLACK_CHANNEL=#recon
DISCORD_WEBHOOK=

# --- Infrastructure ---
PROXY_URL=
USER_AGENT_OVERRIDE=
